# =============================================================================
# .env.local.example — PHASE 11L INTERNAL ACCESS
#
# Copy this file to `.env.local` (which is gitignored and must NEVER be committed)
# and set real values. The middleware (middleware.ts) gates /internal/* with HTTP
# Basic auth using these two variables.
#
# DENY BY DEFAULT: if either variable is unset/empty, every /internal/* request is
# refused with 503. There is no "open" fallback.
#
# For deployed environments (Vercel): set the SAME two variables in
# Project Settings -> Environment Variables. Do not put real credentials in this
# example file or anywhere in the repo.
# =============================================================================

# Username for the internal Pressure Lab basic-auth prompt.
INTERNAL_ACCESS_USER=

# Password for the internal Pressure Lab basic-auth prompt.
# Use a long, random value. Treat it as a secret.
INTERNAL_ACCESS_PASSWORD=
